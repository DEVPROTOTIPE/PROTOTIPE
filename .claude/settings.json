{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.*.local)",
      "Read(**/.env.development)",
      "Read(**/.env.production)",
      "Read(**/.env.test)",
      "Read(**/cli-token.json)",
      "Read(**/firebase-tools.json)",
      "Read(**/*serviceAccount*.json)",
      "Bash(git add .)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git clean *)",
      "Bash(git restore *)",
      "Bash(firebase deploy *)",
      "Bash(npx skills add *)",
      "Bash(npx skills@* add *)",
      "Bash(npx skills use *)",
      "Bash(npx skills@* use *)",
      "Bash(npx skills update *)",
      "Bash(npx skills@* update *)",
      "Bash(npx skills remove *)",
      "Bash(npx skills@* remove *)",
      "Bash(npx skills rm *)",
      "Bash(npx skills@* rm *)",
      "Bash(rm *)",
      "Bash(del *)",
      "Bash(Remove-Item *)"
    ],
    "defaultMode": "plan"
  },
  "enabledPlugins": {
    "ui-ux-pro-max@ui-ux-pro-max-skill": true
  }
}
