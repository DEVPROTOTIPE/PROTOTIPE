{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CapabilitySchema",
  "type": "object",
  "properties": {
    "capabilities": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "displayName": { "type": "string" },
          "description": { "type": "string" },
          "resolvesFeatures": {
            "type": "array",
            "items": { "type": "string" }
          },
          "resolvesComponents": {
            "type": "array",
            "items": { "type": "string" }
          },
          "resolvesPatterns": {
            "type": "array",
            "items": { "type": "string" }
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["displayName", "description", "resolvesFeatures", "resolvesComponents", "resolvesPatterns", "tags"]
      }
    }
  },
  "required": ["capabilities"]
}
