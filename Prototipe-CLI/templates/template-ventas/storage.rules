rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── IMÁGENES DE PRODUCTOS (principal) ────────────────────────────────────
    // Lectura pública para que el catálogo del cliente cargue sin autenticación.
    // Escritura solo para usuarios autenticados (admin).
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── IMÁGENES DE VARIANTES DE PRODUCTOS ───────────────────────────────────
    match /products_variants/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── GALERÍA SECUNDARIA DE PRODUCTOS ──────────────────────────────────────
    match /products_gallery/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── ASSETS DE MARCA (logos, favicon, banners) ────────────────────────────
    match /branding/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── BORRADORES TEMPORALES DE PRODUCTOS ───────────────────────────────────
    match /products_drafts/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── BLOQUEO POR DEFECTO ──────────────────────────────────────────────────
    // Cualquier ruta no listada arriba queda denegada explícitamente.
    match /{everything=**} {
      allow read, write: if false;
    }
  }
}
