rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Configuración general de la app (Branding HSL, flags)
    match /config/settings {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Permitir lectura/escritura en cualquier colección si el usuario está autenticado
    // (Útil para que la IA configure y pruebe el modelo de citas/veterinaria)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
