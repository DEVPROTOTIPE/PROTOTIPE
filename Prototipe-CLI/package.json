{
  "name": "prototipe-cli",
  "version": "1.0.0",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": "22.23.0",
    "npm": "10.9.8"
  },
  "description": "Orquestador interactivo para la inicializacion automatica de proyectos del ecosistema de instancias Prototipe",
  "main": "cli.js",
  "type": "module",
  "scripts": {
    "start": "node cli.js",
    "server": "node --no-warnings server.js",
    "sync": "node sync_templates.js",
    "sync:dry": "node sync_templates.js --dry-run",
    "sync:full": "node sync_templates.js --yes --run-tests",
    "sync:clients": "node sync_clients.js",
    "test": "node test_templates.js",
    "test:all": "node test_templates.js --all",
    "test:verbose": "node test_templates.js --verbose",
    "validate:knowledge": "node scripts/validate-knowledge.js",
    "test:core-promotion": "node scripts/run_full_certification.js",
    "test:core-promotion-certification": "node scripts/run_full_certification.js --strict",
    "test:p0.2": "node scripts/tests/p0_2/run_p0_2_contract_tests.js",
    "test:p0.2:report": "node scripts/tests/p0_2/run_p0_2_contract_tests.js --write-report",
    "test:p0.3": "node scripts/tests/p0_3/run_p0_3_security_tests.js",
    "test:p0.4": "node scripts/tests/p0_4/run_p0_4_lifecycle_tests.js",
    "test:p0.6": "node scripts/tests/p0_6/run_p0_6_queue_tests.js"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "cors": "^2.8.5",
    "diff": "^9.0.0",
    "express": "^4.19.2",
    "firebase": "^12.14.0",
    "firebase-admin": "^12.0.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.12",
    "jimp": "^1.6.1",
    "ora": "^9.4.0",
    "picocolors": "^1.0.0",
    "semver": "^7.8.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "playwright": "^1.61.1"
  }
}
