rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper para verificar si la petición viene de un Administrador autenticado en Firebase Auth
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // SEC-015: helpers de identidad real de empleados (Firebase Auth email/
    // password sintético, vía employeeAuthLinks/{authUid} -> employeeId).
    function isEmployee() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/employeeAuthLinks/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/employeeAuthLinks/$(request.auth.uid)).data.activo == true;
    }
    function employeeId() {
      return get(/databases/$(database)/documents/employeeAuthLinks/$(request.auth.uid)).data.employeeId;
    }

    // Valida que un pedido nuevo tenga la estructura mínima requerida
    function validOrder() {
      let d = request.resource.data;
      return d.keys().hasAll(['items', 'cliente', 'total', 'metodoPago'])
        && d.total is number
        && d.total > 0
        && d.items is list
        && d.items.size() > 0;
    }

    // Configuración global y Filtros
    match /config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Subcolecciones de configuración
    match /config/delivery/messengers/{messengerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Perfiles de usuarios (clientes y administradores)
    match /users/{userId} {
      allow get: if true;
      
      // Permitir creación pública solo si el rol asignado es estrictamente 'client'
      // O si la petición proviene de un administrador autenticado.
      // SEC-013 (2026-07-15): se retiró isFirstStart() — el bootstrap del primer
      // admin y de config/settings ahora se hace exclusivamente server-side vía
      // Admin SDK (ver Prototipe-CLI/scripts/bootstrap-admin.js), que ignora
      // las reglas de cliente por diseño. Ningún cliente anónimo puede volver
      // a auto-otorgarse admin escribiendo cuando la base está vacía.
      // SEC-014 (2026-07-15): la creación de un cliente exige sesión anónima
      // real (useAnonAuthInit) y que ownerUid quede vinculado a esa sesión.
      allow create: if (
          request.resource.data.role == 'client' &&
          request.auth != null &&
          request.resource.data.ownerUid == request.auth.uid
        ) || isAdmin();

      // Permitir actualización de campos personales pero impedir escalar de 'client' a 'admin'.
      // SEC-014: ownerUid solo puede quedar igual (auto-actualización normal) o
      // rellenarse una vez desde null (backfill de clientes pre-SEC-014 en su
      // primer login tras el cambio) — nunca reasignarse a otra sesión.
      allow update: if isAdmin() || (
        request.auth != null &&
        request.resource.data.role == 'client' &&
        (resource.data.role == 'client' || resource.data.role == null) &&
        (
          request.resource.data.ownerUid == resource.data.ownerUid ||
          (resource.data.ownerUid == null && request.resource.data.ownerUid == request.auth.uid)
        )
      );

      allow list, delete: if isAdmin();

      // SEC-014: solo la sesión vinculada (ownerUid) al perfil padre puede
      // leer/escribir sus propios favoritos.
      match /favorites/{favoriteId} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(userId)).data.ownerUid == request.auth.uid;
      }
    }

    // Catálogo e Inventario
    match /products/{document} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['variantes', 'salesCount', 'updatedAt'])
      );
    }
    match /categories/{document} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // Pedidos (Retail y Mayoristas)
    // [SEGURIDAD - FASE 1] orders create ahora valida estructura mínima.
    // SEC-014 (2026-07-15): confirmado por búsqueda que el cliente ya no lee
    // esta colección directamente (usa order_tracking/user_order_index vía
    // trackingToken) — se completa la migración pendiente restringiendo a admin.
    match /orders/{document} {
      // SEC-015: validOrder() sigue rigiendo la estructura; si el pedido
      // reclama atribución de un vendedor de portal (vendedorId), esa
      // atribución debe corresponder a la sesión real de ese empleado —
      // no bloquea el checkout normal de clientes, que no manda ese campo.
      allow create: if validOrder() && (
        !('vendedorId' in request.resource.data) ||
        (isEmployee() && request.resource.data.vendedorId == employeeId())
      );
      allow read: if isAdmin();
      allow update: if isAdmin() || (
        // Permitir a repartidores/empleados operativos actualizar el estado de entrega o producción
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado', 'deliveryInfo', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    // [NUEVO - FASE 1] Seguimiento público de pedidos (sin PII)
    // Esta colección reemplaza la lectura pública de orders/.
    // Contiene únicamente: estado, número de pedido, tipo de entrega,
    //   resumen financiero e items (sin teléfono ni datos bancarios del cliente).
    match /order_tracking/{trackingToken} {
      allow get: if true;            // Público: página de seguimiento por token
      allow list: if isAdmin();      // Restringido: nadie puede listar toda la colección
      allow create: if true;         // createOrder() desde cliente escribe aquí
      allow update: if isAdmin()     // Admin actualiza estado
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado', 'updatedAt']);
      allow delete: if isAdmin();
    }
    
    // [NUEVO - FASE 1] Índice de pedidos por hash de celular
    // Permite al cliente listar las referencias de sus pedidos sin auth.
    match /user_order_index/{hashedCelular} {
      allow get: if true;
      allow list: if isAdmin();

      match /orders/{trackingToken} {
        allow read: if true;         // Permite al cliente listar/leer sus propios tokens
        allow create: if request.resource.data.keys().hasAll(['trackingToken', 'orderId', 'createdAt', 'updatedAt'])
          && request.resource.data.trackingToken == trackingToken
          && request.resource.data.orderId.matches('^[a-zA-Z0-9_-]{20}$');
        allow update, delete: if isAdmin();
      }
    }

    // SEC-014 (2026-07-15): create exige sesión anónima real (accountability
    // mínima); se preserva la tolerancia existente a clienteCelular:'Desconocido'
    // para envíos sin login. Read restringido a admin o al dueño vinculado.
    match /wholesaleOrders/{document} {
      allow create: if request.auth != null;
      allow read: if isAdmin() || (
        request.auth != null &&
        resource.data.clienteCelular is string &&
        resource.data.clienteCelular != 'Desconocido' &&
        get(/databases/$(database)/documents/users/$(resource.data.clienteCelular)).data.ownerUid == request.auth.uid
      );
      allow update, delete: if isAdmin();
    }

    // Créditos / Fiados
    // SEC-014 (2026-07-15): lectura restringida a admin o al cliente dueño
    // del celular asociado (cliente.celular), vía ownerUid del perfil.
    match /credits/{document} {
      allow read: if isAdmin() || (
        request.auth != null &&
        get(/databases/$(database)/documents/users/$(resource.data.cliente.celular)).data.ownerUid == request.auth.uid
      );
      allow write: if isAdmin();
    }

    // Publicidad y Promociones
    match /ads/{document} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // Cupones
    match /coupons/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Garantías y Reclamos
    match /claims/{document} {
      allow create: if true;
      allow read: if isAdmin() || (request.auth != null && request.auth.token.phone_number == resource.data.clienteCelular);
      allow update, delete: if isAdmin();
    }

    // [NUEVO] Centro de Notificaciones Centralizado
    // - create: abierto (clientes, empleados y servicios internos crean notificaciones)
    // - read: admins, clientes o si la notificación pertenece al rol consultado
    // - update: admins, o cualquier usuario que solo modifique el campo 'status'
    //           (para marcar como leída o archivar desde portales de empleados sin Auth)
    // - delete: solo admins
    match /notifications/{document} {
      // SEC-015: create exige al menos una sesión real (clientes vía
      // SEC-014, empleados vía SEC-015 ya cubren esto automáticamente).
      // No se usa isEmployee() aquí — createCentralNotification también la
      // llaman flujos de clientes (orderService, creditService), no solo
      // los portales.
      allow create: if request.auth != null;
      allow read: if isAdmin() || resource.data.recipientRole == 'client';
      allow update: if isAdmin()
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if isAdmin() || resource.data.recipientRole == 'client' || resource.data.recipientRole == 'vendedor' || resource.data.recipientRole == 'bodeguero' || resource.data.recipientRole == 'mensajero';
    }

    // [NUEVO] Registro de Tokens FCM (Dispositivos)
    match /fcmTokens/{document} {
      allow read: if isAdmin();
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // Notificaciones del Cliente (Legacy compatibility)
    match /clientNotifications/{document} {
      allow read: if isAdmin() || (request.auth != null && request.auth.token.phone_number == resource.data.clienteCelular);
      allow create: if true;
      allow update: if isAdmin() || (request.auth != null && request.auth.token.phone_number == resource.data.clienteCelular);
      allow delete: if isAdmin();
    }

    // Configuración y PINs de empleados (Altamente sensible)
    match /employees/{employeeId} {
      allow read: if isAdmin() || (resource != null && resource.data.activo == true);
      allow write: if isAdmin();

      // Subcolección legacy de hashes de PIN (SEC-015: ya no se usa para
      // login — reemplazada por Firebase Auth real vía employeeAuthLinks.
      // Se conserva bloqueada como colección muerta, nunca se reactiva.
      match /secrets/{hashedPin} {
        allow read, write: if isAdmin();
      }
    }

    // SEC-015: índice inverso authUid (Firebase Auth) -> employeeId, usado
    // por isEmployee()/employeeId(). Solo isAdmin() escribe (provisión vía
    // employeeAuthService/reset-employee-pin.js); el propio empleado puede
    // leer su propio vínculo.
    match /employeeAuthLinks/{authUid} {
      allow read: if isAdmin() || request.auth.uid == authUid;
      allow write: if isAdmin();
    }

    // Entregas y despachos
    match /deliveries/{deliveryId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // SEC-015: antes cualquier request.auth != null podía actualizar
      // (incluye a cualquier visitante anónimo desde SEC-014) — se acota a
      // empleados reales o admin.
      allow update: if isAdmin() || (
        isEmployee() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado', 'history', 'updatedAt', 'deliveredAt'])
      );
    }

    // Kardex y Movimientos de Stock
    // [SEGURIDAD] Lectura restringida a admin: los movimientos de stock son información
    //  comercial sensible (volúmenes, proveedores, ajustes internos).
    match /stockMovements/{movementId} {
      allow read: if isAdmin();
      // SEC-015: el sistema ya no escribe "automáticamente" sin identidad —
      // exige que sea un empleado real (bodeguero) o un admin, y que el
      // employeeId declarado corresponda a la sesión que escribe.
      allow create: if isAdmin() || (isEmployee() && request.resource.data.employeeId == employeeId());
      allow update, delete: if isAdmin();
    }

    // Historial de Accesos y Sesiones QR
    match /accessLogs/{logId} {
      allow read: if isAdmin();
      // SEC-015: create/update ya no aceptan cualquier request sin
      // identidad — deben venir de la sesión real del empleado que el log
      // declara (o de admin).
      allow create: if isAdmin() || (isEmployee() && request.resource.data.employeeId == employeeId());
      allow update: if isAdmin() || (isEmployee() && resource.data.employeeId == employeeId());
      allow delete: if isAdmin();
    }

    // Analíticas de Códigos QR
    match /qrAnalytics/{analyticsId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Telemetría y Analíticas
    match /trackingAnalytics/{analyticsId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Colección de diagnóstico temporal para desarrolladores
    match /_diagnostics/{document} {
      allow read, write: if isAdmin();
    }
  }
}
