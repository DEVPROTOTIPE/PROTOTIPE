{
  "name": "app-ventas",
  "private": true,
  "version": "1.0.6",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": "22.23.0",
    "npm": "10.9.8"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "validate": "node scripts/validate-core-integrity.js",
    "test": "vitest run",
    "test:ui": "playwright test",
    "test:ui:show": "playwright test --ui",
    "test:ci": "playwright test --reporter=list",
    "ci": "npm run lint && npm run validate && npm run build && npm run test:ci",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\""
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.11",
    "canvas-confetti": "^1.9.4",
