    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.3.0",
    "vite": "^6.0.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
