# ─── FIREBASE DEL CLIENTE (se configura por app) ───────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── IDENTIDAD DEL CLIENTE EN EL ECOSISTEMA ─────────────────────────────────
VITE_DEVELOPER_CLIENT_ID=
VITE_DEVELOPER_TELEMETRY_TOKEN=
VITE_NICHE=general

# ─── FIREBASE CENTRAL DEL DESARROLLADOR (igual para todas las apps) ─────────
VITE_DEVELOPER_CENTRAL_API_KEY=
VITE_DEVELOPER_CENTRAL_AUTH_DOMAIN=
VITE_DEVELOPER_CENTRAL_PROJECT_ID=prototipe-ecosistema-control
VITE_DEVELOPER_CENTRAL_STORAGE_BUCKET=
VITE_DEVELOPER_CENTRAL_MESSAGING_SENDER_ID=
VITE_DEVELOPER_CENTRAL_APP_ID=

# ─── CONFIGURACIÓN DE FACTURACIÓN (defaults que el CRM puede sobreescribir) ─
VITE_DEVELOPER_BILLING_MODE=percentage
VITE_DEVELOPER_COMMISSION_PERCENT=5
VITE_DEVELOPER_FIXED_SERVICE_FEE=0
VITE_DEVELOPER_FLAT_MONTHLY_FEE=0
VITE_DEVELOPER_ENABLE_DIAN_BILLING=false
VITE_DEVELOPER_COSTO_POR_FACTURA_DIAN=0
