rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPERS GLOBALES DE ACCESO ──────────────────────────────────

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── REGLAS CORE POR COLECCIÓN ──────────────────────────────────

    // 0. Telemetría Multitenant
    match /clientes_control/{clientId} {
      allow read: if request.auth != null && (clientId == request.auth.token.clientId || isAdmin());
      allow write: if isAdmin();
    }

    // 1. Configuración Global
    match /config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. Usuarios y Clientes
    // userId = UID de Firebase Auth (admin) o número de celular (cliente sin auth)
    match /users/{userId} {
      allow read: if isAdmin()
        || (request.auth != null && request.auth.uid == userId)
        || true; // Login de cliente sin auth

      allow create: if isAdmin()
        || (request.auth != null && request.auth.uid == userId)
        || true;

      allow update: if isAdmin()
        || (request.auth != null && request.auth.uid == userId)
        || true;

      allow list: if isAdmin();
      allow delete: if isAdmin();

      match /favorites/{favoriteId} {
        allow read, write: if isAdmin() || true;
      }
    }

    // ─── FEATURE ORDERS ────────────────────────────────────────────
    match /orders/{document} {
      allow read: if isAdmin() || true;
      allow create: if true;
      allow update: if isAdmin() || true;
      allow delete: if isAdmin();
    }

    match /wholesaleOrders/{document} {
      allow read: if isAdmin() || true;
      allow create: if true;
      allow update: if isAdmin() || true;
      allow delete: if isAdmin();
    }

    match /order_tracking/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── FEATURE CREDITS ────────────────────────────────────────────
    match /credits/{document} {
      allow read: if isAdmin() || true;
      allow write, delete: if isAdmin();
    }

    // ─── FEATURE INVENTORY ──────────────────────────────────────────
    match /products/{document} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['variantes', 'salesCount', 'updatedAt'])
      );
    }

    match /categories/{document} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // ─── FEATURE ADS ────────────────────────────────────────────────
    match /ads/{document} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // ─── FEATURE COUPONS ────────────────────────────────────────────
    match /coupons/{document} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // ─── FEATURE CLAIMS ─────────────────────────────────────────────
    match /claims/{document} {
      allow read: if isAdmin() || true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // ─── FEATURE EMPLOYEES & OPERATIONS ─────────────────────────────
    match /employees/{document} {
      allow read, write, delete: if isAdmin();
    }

    match /tables/{document} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    match /production/{document} {
      allow read, write, delete: if isAdmin();
    }

    match /deliveries/{document} {
      allow read: if isAdmin() || true;
      allow write, delete: if isAdmin();
    }

    match /stockMovements/{document} {
      allow read, write, delete: if isAdmin();
    }

    match /accessLogs/{document} {
      allow read, delete: if isAdmin();
      allow create: if true;
      allow update: if isAdmin();
    }

    match /deliveryAnalytics/{document} {
      allow read, write: if isAdmin();
    }

    match /trackingAnalytics/{document} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // ─── FEATURE NOTIFICATIONS ───────────────────────────────────────
    match /notifications/{document} {
      allow create: if true;
      allow read: if isAdmin() || resource.data.recipientRole == 'client';
      allow update: if isAdmin()
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if isAdmin()
        || resource.data.recipientRole == 'client'
        || resource.data.recipientRole == 'vendedor'
        || resource.data.recipientRole == 'bodeguero'
        || resource.data.recipientRole == 'mensajero';
    }

    match /fcmTokens/{document} {
      allow read: if isAdmin();
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    match /clientNotifications/{document} {
      allow read: if isAdmin() || true;
      allow create: if true;
      allow update: if isAdmin() || true;
      allow delete: if isAdmin();
    }

  }
}
